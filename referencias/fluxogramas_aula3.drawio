<mxfile host="app.diagrams.net">
  <diagram name="Ciclo while — Guardiao da Porta" id="aula3-while">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- INÍCIO -->
        <mxCell id="2" value="INÍCIO" style="ellipse;whiteSpace=wrap;html=1;fillColor=#00C851;strokeColor=#007A32;fontColor=#ffffff;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="190" y="40" width="140" height="60" as="geometry"/>
        </mxCell>

        <!-- INÍCIO → tentativas = 0 -->
        <mxCell id="3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="2" target="4" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- PROCESSO: tentativas = 0 -->
        <mxCell id="4" value="tentativas = 0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1D6FA4;strokeColor=#1354A0;fontColor=#ffffff;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="185" y="150" width="150" height="55" as="geometry"/>
        </mxCell>

        <!-- tentativas = 0 → DECISÃO -->
        <mxCell id="5" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="4" target="6" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- DECISÃO: tentativas < 3? -->
        <mxCell id="6" value="tentativas &lt; 3?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FF8C00;strokeColor=#CC7000;fontColor=#ffffff;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="175" y="255" width="170" height="90" as="geometry"/>
        </mxCell>

        <!-- Sim → INPUT -->
        <mxCell id="7" value="Sim" style="edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" edge="1" source="6" target="8" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- INPUT: pw = input() -->
        <mxCell id="8" value="pw = input(&quot;Password: &quot;)" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#1D6FA4;strokeColor=#1354A0;fontColor=#ffffff;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="160" y="395" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- INPUT → DECISÃO pw correto? -->
        <mxCell id="9" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="8" target="10" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- DECISÃO: pw == "cyber2025"? -->
        <mxCell id="10" value='pw == &quot;cyber2025&quot;?' style="rhombus;whiteSpace=wrap;html=1;fillColor=#FF8C00;strokeColor=#CC7000;fontColor=#ffffff;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="175" y="505" width="170" height="90" as="geometry"/>
        </mxCell>

        <!-- Sim → OUTPUT acesso concedido -->
        <mxCell id="11" value="Sim" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="10" target="12" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- OUTPUT: acesso concedido -->
        <mxCell id="12" value='print("Acesso concedido!")' style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#00C851;strokeColor=#007A32;fontColor=#ffffff;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="420" y="520" width="210" height="60" as="geometry"/>
        </mxCell>

        <!-- Nao → tentativas += 1 -->
        <mxCell id="13" value="Não" style="edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" edge="1" source="10" target="14" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- PROCESSO: tentativas += 1 -->
        <mxCell id="14" value="tentativas += 1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1D6FA4;strokeColor=#1354A0;fontColor=#ffffff;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="185" y="645" width="150" height="55" as="geometry"/>
        </mxCell>

        <!-- tentativas += 1 → volta à DECISÃO (seta de retorno) -->
        <mxCell id="15" value="" style="edgeStyle=orthogonalEdgeStyle;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="14" target="6" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="80" y="672"/>
              <mxPoint x="80" y="300"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Nao (decisao while) → OUTPUT bloqueado -->
        <mxCell id="16" value="Não" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="6" target="17" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- OUTPUT: bloqueado -->
        <mxCell id="17" value='print("Sistema bloqueado")' style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#E53935;strokeColor=#B71C1C;fontColor=#ffffff;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="420" y="270" width="210" height="60" as="geometry"/>
        </mxCell>

        <!-- acesso concedido → FIM -->
        <mxCell id="18" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="12" target="19" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="680" y="550"/>
              <mxPoint x="680" y="840"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- bloqueado → FIM -->
        <mxCell id="20" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="17" target="19" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="680" y="300"/>
              <mxPoint x="680" y="840"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- FIM -->
        <mxCell id="19" value="FIM" style="ellipse;whiteSpace=wrap;html=1;fillColor=#00C851;strokeColor=#007A32;fontColor=#ffffff;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="190" y="810" width="140" height="60" as="geometry"/>
        </mxCell>

        <!-- FIM ← tentativas += 1 (se necessário via loop) -->
        <mxCell id="21" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="19" target="19" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Label "Repete o ciclo" na seta de retorno -->
        <mxCell id="22" value="Repete" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=2;fontColor=#FF8C00;" vertex="1" parent="1">
          <mxGeometry x="20" y="460" width="60" height="30" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
